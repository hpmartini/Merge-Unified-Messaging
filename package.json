{
  "name": "merge---unified-messaging",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:all": "concurrently \"npm run dev\" \"npm run proxy\" \"npm run whatsapp\" \"npm run signal\"",
    "proxy": "node server/ai-proxy.js",
    "whatsapp": "node server/whatsapp-server.js",
    "signal": "node server/signal-server.js",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "node scripts/install-signal-cli.js",
    "start": "node server/ai-proxy.js",
    "deploy": "docker-compose -f docker-compose.prod.yml up -d --build",
    "deploy:down": "docker-compose -f docker-compose.prod.yml down",
    "db:migrate": "node server/db/migrate.js",
    "start:proxy": "npm run db:migrate && node server/ai-proxy.js"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@google/generative-ai": "^0.24.1",
    "@slack/bolt": "^4.7.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "imapflow": "^1.3.1",
    "jsonwebtoken": "^9.0.3",
    "keytar": "^7.9.0",
    "lucide-react": "^0.475.0",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^10.5.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "9.0.0",
    "react-router-dom": "^7.14.0",
    "remark-gfm": "4.0.0",
    "telegraf": "^4.16.3",
    "uuid": "^13.0.0",
    "whatsapp-web.js": "^1.34.6",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.3"
  }
}
