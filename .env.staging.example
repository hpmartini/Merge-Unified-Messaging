# -----------------------------------------------------------------------------
# Staging Environment Variables
# COPY this file to .env.staging and fill in your values
# DO NOT COMMIT .env.staging with real secrets!
# -----------------------------------------------------------------------------

# AI Proxy Settings
NODE_ENV=production
AI_PROXY_PORT=3044
FRONTEND_URL=http://localhost:8080

# Secrets (Inject safely in CI/CD or staging server)
GEMINI_API_KEY=your_gemini_api_key_here

# Rate Limiting & Logging
AI_RATE_LIMIT_REQUESTS=60
LOG_LEVEL=info